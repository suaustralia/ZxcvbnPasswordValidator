{
  "name": "suqld/zxcvbn-password-validator",
  "description": "Realistic Symfony password strength validator based on Zxcvbn PHP ",
  "keywords": ["password", "validator", "symfony", "php", "dropbox", "zxcvb"],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Locastic",
      "email": "info@locastic.com",
      "homepage": "https://www.locastic.com"
    }
  ],
  "require": {
    "php": "^7.2 | ^8.0",
    "bjeavons/zxcvbn-php": "^1.3.1",
    "symfony/translation": "^5.4.2",
    "symfony/validator": "^4.0 || ^5.4.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5.11",
    "symfony/phpunit-bridge": "^4.1 || ^5.4"
  },
  "autoload": {
    "psr-4": {
      "Locastic\\Component\\ZxcvbnPasswordValidator\\": "src/"
    },
    "exclude-from-classmap": ["test/"]
  },
  "autoload-dev": {
    "psr-4": {
      "Locastic\\Component\\ZxcvbnPasswordValidator\\Tests\\": "tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "1.0-dev"
    }
  },
  "config": {
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true
  }
}
